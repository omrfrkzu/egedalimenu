{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/en/bakım-sayfası",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/en/bak%C4%B1m-sayfas%C4%B1",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/bakım-sayfası",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/bak%C4%B1m-sayfas%C4%B1",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/maintenance",
      "destination": "/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/menu/(.*).json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    }
  ]
}




